{
  "name": "@dallenpyrah/pi",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.14",
  "description": "Dallen Pyrah's shareable Pi setup: configs, skills, prompts, themes, and extensions.",
  "keywords": [
    "pi-package",
    "pi",
    "agent-skills"
  ],
  "scripts": {
    "postinstall": "bash scripts/disable-opencode-web-autostart.sh || true",
    "sync": "bash scripts/sync-from-local.sh",
    "install:local": "bash scripts/install.sh",
    "disable:opencode-web": "bash scripts/disable-opencode-web-autostart.sh",
    "verify": "bun scripts/verify-no-secrets.mjs"
  },
  "dependencies": {
    "@ygncode/pi-web": "^0.0.1-beta.34",
    "amp-themes": "^0.4.1",
    "pi-subagents": "^0.30.0",
    "effect": "^4.0.0-beta.66"
  },
  "bundledDependencies": [
    "@ygncode/pi-web",
    "amp-themes",
    "pi-subagents"
  ],
  "trustedDependencies": [
    "@ygncode/pi-web"
  ],
  "pi": {
    "extensions": [
      "./extensions/amp-startup-screen.ts",
      "./extensions/amp-modes.ts",
      "./node_modules/amp-themes/extensions/amp-appearance.ts",
      "./node_modules/amp-themes/extensions/amp-editor.ts",
      "./node_modules/amp-themes/extensions/amp-tool-display.ts",
      "./node_modules/amp-themes/extensions/amp-user-message.ts",
      "./node_modules/pi-subagents/src/extension/index.ts"
    ],
    "skills": [
      "./skills",
      "./node_modules/@ygncode/pi-web/.pi/skills",
      "./node_modules/pi-subagents/skills"
    ],
    "prompts": [
      "./prompts",
      "./node_modules/pi-subagents/prompts"
    ],
    "themes": [
      "./themes",
      "./node_modules/amp-themes/themes"
    ],
    "subagents": {
      "agents": [
        "./agents"
      ]
    }
  }
}
